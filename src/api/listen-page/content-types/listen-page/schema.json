{
  "kind": "collectionType",
  "collectionName": "listen_pages",
  "info": {
    "singularName": "listen-page",
    "pluralName": "listen-pages",
    "displayName": "Listen Page",
    "description": "Streaming platform links and player content for a site's /listen page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "spotifyPlaylistURL": {
      "type": "string",
      "regex": "^https://open\\.spotify\\.com/(intl-[a-z]{2}(-[A-Z]{2})?/)?playlist/[A-Za-z0-9]+([?#].*)?$"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "bandcamp": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "spotify": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "tidal": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "appleMusic": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "itunesStore": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "deezer": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "amazonMusic": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "youtubeMusic": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "qobuz": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "pandora": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "soundcloud": {
      "type": "string",
      "regex": "^https?://\\S+$"
    },
    "site": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::site.site",
      "inversedBy": "listenPages"
    }
  }
}
